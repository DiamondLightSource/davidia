{
  "name": "davidia",
  "repository": {
    "type": "git",
    "url": "https://github.com/DiamondLightSource/davidia.git"
  },
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "start": "pnpm --filter {client/example} start",
    "build": "pnpm --filter {client/*} build",
    "start:storybook": "pnpm --filter storybook start",
    "build:storybook": "pnpm --filter storybook build && pnpx cpy-cli typedocs/index.html storybook/storybook-static/",
    "test": "pnpm --filter {client/component} test",
    "prettify": "prettier -w client storybook",
    "lint": "pnpm --filter {client/*} --filter storybook lint",
    "lint-fix": "pnpm --filter {client/*} --filter storybook lint-fix",
    "lint:tsc": "pnpm tsc --noEmit",
    "docs": "pnpm --filter {client/component} run docs",
    "bump-vpatch": "pnpm --filter {client/*} --filter storybook exec pnpm version patch"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.39.5",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^5.2.0",
    "acorn": "^8.17.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "vite": "^8.1.3"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ],
  "dependencies": {
    "@diamondlightsource/davidia": "link:client/component"
  }
}
